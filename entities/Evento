{
  "name": "Evento",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string"
    },
    "descricao": {
      "type": "string"
    },
    "data": {
      "type": "string",
      "format": "date"
    },
    "hora": {
      "type": "string"
    },
    "local": {
      "type": "string"
    },
    "coral_id": {
      "type": "string"
    },
    "autor_nome": {
      "type": "string"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "ensaio",
        "apresentacao",
        "reuniao",
        "outro"
      ],
      "default": "ensaio"
    }
  },
  "required": [
    "titulo",
    "data",
    "coral_id"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "data.coral_id": "{{user.data.active_coral_id}}"
            },
            {
              "$or": [
                {
                  "user.data.active_coral_role": "maestro"
                },
                {
                  "user.data.active_coral_role": "secretaria"
                },
                {
                  "user.data.active_coral_role": "vice_secretaria"
                }
              ]
            }
          ]
        }
      ]
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.coral_id": "{{user.data.active_coral_id}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "data.coral_id": "{{user.data.active_coral_id}}"
            },
            {
              "$or": [
                {
                  "user.data.active_coral_role": "maestro"
                },
                {
                  "user.data.active_coral_role": "secretaria"
                },
                {
                  "user.data.active_coral_role": "vice_secretaria"
                }
              ]
            }
          ]
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "data.coral_id": "{{user.data.active_coral_id}}"
            },
            {
              "$or": [
                {
                  "user.data.active_coral_role": "maestro"
                },
                {
                  "user.data.active_coral_role": "secretaria"
                },
                {
                  "user.data.active_coral_role": "vice_secretaria"
                }
              ]
            }
          ]
        }
      ]
    }
  }
}